datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  servings    Int?
  prepMinutes Int?
  cookMinutes Int?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  tags        RecipeTag[]
  images      RecipeImage[]
}

model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  instruction String
  order       Int

  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model Ingredient {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes   RecipeIngredient[]
}

model RecipeIngredient {
  recipeId     String
  ingredientId String

  quantity     String?
  unit         String?
  note         String?

  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@id([recipeId, ingredientId])
  @@index([ingredientId])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  recipes RecipeTag[]
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@index([tagId])
}

model RecipeImage {
  id        String   @id @default(cuid())
  recipeId  String
  key       String
  url       String?
  mimeType  String?
  createdAt DateTime @default(now())

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}
