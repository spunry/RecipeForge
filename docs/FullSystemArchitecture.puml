@startuml
title Full System Architecture

skinparam shadowing false
skinparam componentStyle rectangle
skinparam wrapWidth 220
skinparam maxMessageSize 220

'========================
' Clients
'========================
package "Clients" #EEF6FF {
  [Desktop Browser\n(Chrome/Firefox/Safari)] as WebClient
  [Mobile Browser\n(Responsive/PWA)] as MobileClient
}

'========================
' Edge / Delivery
'========================
package "Edge / Delivery" #F5F3FF {
  [DNS] as DNS
  [CDN + Edge Cache\n(Vercel Edge / Cloudflare)] as CDN
  [WAF / DDoS Protection\n(optional)] as WAF
}

'========================
' Application (Next.js)
'========================
package "Application (Next.js TypeScript)" #ECFDF5 {

  package "UI Layer" #D1FAE5 {
    [App Router Pages\n/recipes /shopping /search] as UI
    [Client Components\nForms, Lists, Filters] as ClientComponents
    [Server Components\nData Fetch, SSR] as ServerComponents
  }

  package "API Layer" #BBF7D0 {
    [Route Handlers\n/app/api/*] as API
    [Input Validation\n(Zod)] as Validation
    [Auth Middleware\n(NextAuth/Clerk)] as AuthMiddleware
    [Rate Limiter\n(optional)] as RateLimit
  }

  package "Domain + Services" #A7F3D0 {
    [Recipe Service\nCRUD, scaling rules] as RecipeService
    [Shopping List Service\nAggregation, merging] as ShopService
    [Search Service\nFTS now / Search engine later] as SearchService
    [Media Service\nSigned URLs, metadata] as MediaService
  }

  package "Data Access" #6EE7B7 {
    [Repository Layer\n(Prisma wrappers)] as Repo
    [Prisma ORM] as Prisma
  }
}

'========================
' Data Stores
'========================
package "Data Stores" #FFFBEB {
  database "PostgreSQL\n(Recipes, Ingredients,\nLists, Users, Tags)" as Postgres
  [Redis\n(Cache + Rate Limit + Sessions)\n(optional)] as Redis
}

'========================
' File / Media Storage
'========================
package "Media Storage" #FFF1F2 {
  component "Object Storage\nS3 / R2 / MinIO\nRecipe images and uploads" as ObjectStorage
  component "Image Processing\nresize and optimize\n(optional)" as ImgProc
}
'========================
' Search (optional upgrade path)
'========================
package "Search Infrastructure (Phase 2)" #F0F9FF {
  [Meilisearch / Elasticsearch\n(optional later)] as SearchEngine
  [Indexer Worker\n(sync DB -> search)] as Indexer
}

'========================
' Background Jobs + Events
'========================
package "Async / Background" #FAE8FF {
  [Job Queue\n(BullMQ/Cloud Tasks)\n(optional)] as Queue
  [Worker Service\n(Email, indexing,\nimage processing)] as Worker
}

'========================
' Observability
'========================
package "Observability" #F8FAFC {
  [Logging\n(Structured logs)] as Logging
  [Metrics\n(Prometheus/SaaS)] as Metrics
  [Error Tracking\n(Sentry)] as Sentry
}

'========================
' Future SaaS (Optional)
'========================
package "Future SaaS Modules (Optional)" #FFE4E6 {
  [Billing Provider\n(Stripe)] as Stripe
  [Admin Dashboard\n(Ops/Support)] as Admin
  [Multi-tenant Isolation\n(org/user scopes)] as Tenancy
}

'========================
' Flows
'========================
WebClient --> DNS
MobileClient --> DNS
DNS --> CDN
CDN --> WAF
WAF --> UI

UI --> ServerComponents
UI --> ClientComponents

ClientComponents --> API : HTTPS (fetch)
ServerComponents --> API : Server-side calls

API --> Validation
API --> AuthMiddleware
API --> RateLimit
RateLimit --> Redis : counters (optional)

API --> RecipeService
API --> ShopService
API --> SearchService
API --> MediaService

RecipeService --> Repo
ShopService --> Repo
SearchService --> Repo
MediaService --> Repo

Repo --> Prisma
Prisma --> Postgres

SearchService --> Postgres : Phase 1: FTS (tsvector)
SearchService --> SearchEngine : Phase 2: query (optional)

MediaService --> ObjectStorage : Upload/Download\n(pre-signed URLs)
ObjectStorage --> ImgProc : optional transforms

RecipeService --> Queue : async tasks (optional)
MediaService --> Queue : image jobs (optional)
Queue --> Worker
Worker --> Indexer : trigger reindex (optional)
Indexer --> SearchEngine
Indexer --> Postgres : read changes

API --> Logging
API --> Metrics
API --> Sentry
Worker --> Logging
Worker --> Metrics
Worker --> Sentry

AuthMiddleware --> Tenancy : enforce scopes (future)
API --> Stripe : subscriptions (future)
Admin --> Postgres : support tools (future)

@enduml
